{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "vless-reality-in",
      "listen": "CHANGE_ME_LISTEN_ADDRESS",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "CHANGE_ME_UUID",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "www.cloudflare.com:443",
          "xver": 0,
          "serverNames": [
            "www.cloudflare.com"
          ],
          "privateKey": "CHANGE_ME_REALITY_PRIVATE_KEY",
          "shortIds": [
            "CHANGE_ME_SHORT_ID"
          ]
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "isp-socks5",
      "protocol": "socks",
      "settings": {
        "servers": [
          {
            "address": "CHANGE_ME_ISP_SOCKS5_IP",
            "port": 1080,
            "users": [
              {
                "user": "CHANGE_ME_ISP_SOCKS5_USER",
                "pass": "CHANGE_ME_ISP_SOCKS5_PASSWORD"
              }
            ]
          }
        ]
      }
    },
    {
      "tag": "block",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "network": "tcp,udp",
        "outboundTag": "isp-socks5"
      }
    ]
  }
}
